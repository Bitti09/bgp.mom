---
import Layout from "../layouts/Layout.astro";
import ProviderGrid from "../components/ProviderGrid.astro";
import { getCollection } from "astro:content";

const vpsEntries = await getCollection("vps");
// Filter for providers that have "Tunnels" in their services
const tunnelProviders = vpsEntries.filter(entry => 
  entry.data.services.some(service => service.toLowerCase().includes("tunnel"))
);
const sortedProviders = [...tunnelProviders].sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<Layout title="BGP.mom - Tunnel Providers with BGP support">
    <div class="text-center mb-8">
      <h1 class="text-4xl font-bold text-base-content mb-2">Tunnel Providers</h1>
      <p class="text-lg text-base-content/70">Providers offering BGP tunnel services (GRE, IPSec, WireGuard)</p>
      <p class="text-sm text-base-content/50 mt-2">Found {sortedProviders.length} providers</p>
    </div>
    
    <ProviderGrid providers={sortedProviders} />
    
    {sortedProviders.length === 0 && (
      <div class="text-center py-12">
        <p class="text-xl text-base-content/70">No tunnel providers found.</p>
      </div>
    )}
</Layout>
