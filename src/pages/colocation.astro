---
import Layout from "../layouts/Layout.astro";
import ProviderGrid from "../components/ProviderGrid.astro";
import { getCollection } from "astro:content";

const vpsEntries = await getCollection("vps");
// Filter for providers that have "Colocation" in their services
const colocationProviders = vpsEntries.filter(entry => 
  entry.data.services.some(service => service.toLowerCase().includes("colocation"))
);
const sortedProviders = [...colocationProviders].sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<Layout title="BGP.mom - Colocation Providers with BGP support">
  <main class="w-full py-8">
    <div class="text-center mb-8">
      <h1 class="text-4xl font-bold text-base-content mb-2">Colocation Providers</h1>
      <p class="text-lg text-base-content/70">Providers offering colocation services with BGP support</p>
      <p class="text-sm text-base-content/50 mt-2">Found {sortedProviders.length} providers</p>
    </div>
    
    <ProviderGrid providers={sortedProviders} />
    
    {sortedProviders.length === 0 && (
      <div class="text-center py-12">
        <p class="text-xl text-base-content/70">No colocation providers found.</p>
      </div>
    )}
  </main>
</Layout>
