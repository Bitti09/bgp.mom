---
import Layout from "../layouts/Layout.astro";
import ProviderGrid from "../components/ProviderGrid.astro";
import { getSortedProviders } from "../utils/providers";
const sortedProviders = await getSortedProviders(entry => 
  entry.data.services.some(service => 
    service.toLowerCase().includes("transit") || 
    service.toLowerCase().includes("ip transit")
  )
);
---

<Layout title="BGP.mom - IP Transit Providers with BGP support">
    <div class="text-center mb-8">
      <h1 class="text-4xl font-bold text-base-content mb-2">IP Transit Providers</h1>
      <p class="text-lg text-base-content/70">Providers offering IP transit and bandwidth services with BGP support</p>
      <p class="text-sm text-base-content/50 mt-2">Found {sortedProviders.length} providers</p>
    </div>
    
    <ProviderGrid providers={sortedProviders} />
    
    {sortedProviders.length === 0 && (
      <div class="text-center py-12">
        <p class="text-xl text-base-content/70">No IP transit providers found.</p>
      </div>
    )}
</Layout>
